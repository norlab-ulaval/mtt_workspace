<launch>
     <let name="urdf_path" 
          value="$(find-pkg-share mtt_description)/urdf/robot.urdf.xacro"/>

     <let name="rviz_config_path"
          value="$(find-pkg-share mtt_description)/rviz/urdf_config.rviz" />

     <arg name="use_rviz" default="true"/>
     <arg name="use_joint_state_gui" default="true"/>

     <node pkg="robot_state_publisher" exec="robot_state_publisher">
          <param name="robot_description"
               value="$(command 'xacro $(var urdf_path)')"/>
     </node>

     <node pkg="joint_state_publisher_gui" exec="joint_state_publisher_gui" if="$(var use_joint_state_gui)" />

     <node pkg="rviz2" exec="rviz2" output="screen"
           args="-d $(var rviz_config_path)" if="$(var use_rviz)"/>

</launch>
