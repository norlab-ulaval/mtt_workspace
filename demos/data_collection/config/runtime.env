ENABLE_MAPPING=true
ENABLE_SENSORS=true
ENABLE_PERCEPTION=true
ENABLE_TELEOP=true
ENABLE_JOYSTICK=true

GPS_MODE=serial
GPS_ANTENNAS=single
OAK_MODE=stable

MAPPING_POINTS_TOPIC=/merged_points_filtered
MAPPING_DESKEW=false
MAPPING_COMPRESSION_VOXEL_SIZE=0.20
MAPPING_MAP_PUBLISH_RATE=1.0
MAPPING_MAP_TF_PUBLISH_RATE=50.0

JOYSTICK_DEVICE=/dev/input/js0
JOYSTICK_DEADZONE=0.15
