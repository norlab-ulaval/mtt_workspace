ENABLE_MAPPING=true
ENABLE_SENSORS=true
ENABLE_PERCEPTION=true
ENABLE_CLOUD_MERGER=false
ENABLE_TELEOP=true
ENABLE_JOYSTICK=true
ENABLE_GPS=false
ENABLE_OAK=false
ENABLE_MTI10=false

# Field/Doodle network mode.
# Keep false until the real Doodle-connected interface has been identified and
# configured with DOODLE_ROBOT_IP/24. When true, Zenoh and Foxglove bind to the
# Doodle robot IP instead of exposing all host interfaces.
FIELD_NETWORK_MODE=false
DOODLE_ROBOT_IP=192.168.50.2
DOODLE_PC_IP=192.168.50.101
FOXGLOVE_BIND_ADDRESS=192.168.50.2

# Lightweight remote visualization cloud. Raw /hesai_lidar/points stays local.
LIDAR_DEBUG_INPUT_TOPIC=/hesai_lidar/points
LIDAR_DEBUG_OUTPUT_TOPIC=/debug/hesai_points_voxel
LIDAR_DEBUG_VOXEL_SIZE=0.30
LIDAR_DEBUG_MAX_RATE_HZ=2.0
LIDAR_DEBUG_MAX_POINTS=25000

GPS_MODE=serial
GPS_ANTENNAS=single
OAK_MODE=stable

MAPPING_DELAY_SECONDS=10
MAPPING_POINTS_TOPIC=/hesai_lidar/points
# Deskewing uses the odom TF to correct scan distortion during motion.
# At 1.5 m/s / 10 Hz, each scan spans 0.15m — at max yaw rate (~86 deg/s)
# a scan can be smeared by ~8.6 deg without deskewing.
MAPPING_DESKEW=true
MAPPING_COMPRESSION_VOXEL_SIZE=0.50
MAPPING_MAP_PUBLISH_RATE=0.05
MAPPING_MAP_TF_PUBLISH_RATE=50.0
# Quality gate thresholds — relaxed to reduce dropout cascade.
# Hesai XT-32 delivers ~30K pts/scan; after 4 self-filters + 0.9 sampling
# typical outdoor count is 5K-15K. 200 rejects only truly empty scans.
MAPPING_MIN_INPUT_POINTS=200
# 2.5m / 35 deg allow for odom drift accumulation during short rejection windows.
# Dynamic threshold max(limit, 8.0*dt_since_accepted) grows further during cascades.
MAPPING_MAX_TRANSLATION_CORRECTION=2.50
MAPPING_MAX_ROTATION_CORRECTION_DEG=35.0
MAPPING_MAX_VELOCITY_MS=8.0
MAPPING_MAX_YAW_RATE_DEG_S=80.0
# 4.0m pose step matches dynamic threshold at ~0.5s gap (8.0 * 0.5).
MAPPING_MAX_POSE_STEP_M=4.0
MAPPING_MAX_Z_JUMP_M=0.75
# 3000ms gives the Jetson/NUC headroom under concurrent Zenoh + RViz + recording load.
MAPPING_MAX_REGISTRATION_TIME_MS=3000.0
MAPPING_DETERMINISTIC_MAP_UPDATE_DISTANCE_M=0.03
MAPPING_DETERMINISTIC_MAP_UPDATE_YAW_DEG=0.5
MAPPING_DETERMINISTIC_MAP_MIN_DIST_NEW_POINT=0.03
# Large-area mode: trimming OFF + cell-based disk storage (save_map_cells_on_hard_drive=true
# in _icp_mapper.yaml). The library offloads cells >40m from the robot to disk and reloads
# them on demand — global history preserved, memory bounded at ~40m active radius.
# Trimming (hard crop of internal ICP map) is incompatible with sensorMaxRange=80m:
# after a 40m trim the 40-80m ring has no coverage, estimateMapOverlap drops below
# threshold, and ICP rejects every scan until the robot backtracks.
MAPPING_ENABLE_MAP_TRIMMING=false
# Publish radius: crop the PointCloud2 sent to Foxglove to 40m around the robot.
# The ICP internal map is NOT affected — this is visualization bandwidth only.
MAPPING_MAP_PUBLISH_RADIUS_M=40.0

JOYSTICK_DEVICE=/dev/input/js0
JOYSTICK_DEADZONE=0.05

# ---- COM motor (EtherCAT stepper) ----
# Set COM_MOTOR_DRY_RUN=true to test the full ROS chain without hardware.
# Leave COM_ETHERCAT_IFACE empty for auto-detection by Vendor/Product ID.
# Start with: docker compose --profile com up com_motor
COM_MOTOR_DRY_RUN=false
COM_ETHERCAT_IFACE=enp6s0
COM_MOTOR_AUTO_ENABLE=true
