# MTT simulation tuning defaults.
# Edit this file, then recreate the affected service:
#   dcu up -d --force-recreate path_follow
#   dcu up path_arc

SIM_HEADLESS=false
SIM_ENABLE_OPERATOR_CONTROL=false
SIM_ENABLE_JOYSTICK=false
SIM_JOY_DEVICE=/dev/input/js0
SIM_JOY_DEADZONE=0.15

# Keep the robot/test paths away from the obstacle cluster in test_world.sdf
# (most obstacles are around x=0..8, y=-3..4).
SIM_ROBOT_X=-8.0
SIM_ROBOT_Y=-8.0
SIM_ROBOT_YAW=0.0

# Gazebo bridge signs/scales. Yaw sign is set to match the real articulation direction.
# Calibrated from straight-path tests so Gazebo ground truth distance stays
# close to the command/tachometer model odometry.
SIM_WHEEL_GEAR_RATIO=4.20
SIM_WHEEL_COMMAND_SIGN=-1.0
SIM_YAW_COMMAND_SIGN=1.0
SIM_YAW_POSITION_KP=3.2
SIM_YAW_VELOCITY_LIMIT_RAD_S=1.8

# Synthetic tachometer / /mtt_odometry model used only for simulation validation.
# The follower itself uses Gazebo ground truth; these parameters tune how close
# the command/tachometer odom is to the actual simulated robot motion.
SIM_SYNTHETIC_MAX_SPEED=5.56
SIM_SYNTHETIC_MODEL_WHEELBASE=2.05
SIM_SYNTHETIC_MODEL_MAX_ARTICULATION_DEG=60.0
SIM_SYNTHETIC_MODEL_SPEED_RESPONSE_GAIN=3.0
SIM_SYNTHETIC_MODEL_ARTICULATION_RESPONSE_GAIN=2.4
SIM_SYNTHETIC_MODEL_YAW_SLIP_BASE=0.0
SIM_SYNTHETIC_MODEL_YAW_SLIP_SPEED_GAIN=0.0
SIM_SYNTHETIC_MODEL_YAW_SLIP_ARTICULATION_GAIN=0.0
SIM_SYNTHETIC_MODEL_YAW_SLIP_MIN_SCALE=1.0

# Shared real-robot teleop mapping for simulation.
SIM_CONTROL_PARAMS_FILE=${WORKSPACE}/demos/common/config/mtt_control.yaml
SIM_CONTROL_ENABLE_JOYSTICK=true

# Path follower gains.
SIM_PATH_FOLLOWER_PARAMS_FILE=${WORKSPACE}/demos/simulation/config/mtt_path_follower_sim.yaml
SIM_FOLLOWER_MAX_SPEED=4.20
SIM_FOLLOWER_DEFAULT_SPEED=1.00
SIM_FOLLOWER_K_Y=0.32
SIM_FOLLOWER_K_THETA=0.85
SIM_MODEL_L_EQ=2.40
SIM_MODEL_SLIP_BASE=0.10
SIM_MODEL_SLIP_SPEED_GAIN=0.05
SIM_MODEL_SLIP_ARTICULATION_GAIN=0.15
SIM_MODEL_SLIP_MIN_SCALE=0.55
SIM_USE_PATH_CURVATURE_FEEDFORWARD=true
SIM_USE_ADAPTIVE_CURVATURE_BIAS=false
SIM_ADAPTIVE_KAPPA_I_GAIN=0.015
SIM_ADAPTIVE_KAPPA_DECAY=0.08
SIM_ADAPTIVE_KAPPA_DEADBAND_M=0.05
SIM_ADAPTIVE_KAPPA_BIAS_LIMIT=0.08

# Default one-shot test trajectory.
SIM_TEST_SHAPE=s_curve
SIM_TEST_ODOM_TOPIC=/mtt_odometry/ground_truth
SIM_TEST_SPEED=1.50
SIM_TEST_STRAIGHT_SPEED=1.20
SIM_TEST_ARC_SPEED=0.55
SIM_TEST_S_CURVE_SPEED=0.70
SIM_TEST_REVERSE_SPEED=0.35
SIM_TEST_LENGTH=12.0
SIM_TEST_RADIUS=4.0
SIM_TEST_ANGLE_DEG=120.0
SIM_TEST_AMPLITUDE=1.2
SIM_TEST_CYCLES=1.0
SIM_TEST_POINTS=160
SIM_TEST_OFFSET_X=0.0
SIM_TEST_OFFSET_Y=0.0
SIM_TEST_OFFSET_YAW_DEG=0.0
SIM_REVERSE_TEST_LENGTH=5.0
SIM_REVERSE_TEST_RADIUS=3.0
SIM_REVERSE_TEST_ANGLE_DEG=-90.0
SIM_REVERSE_TEST_OFFSET_X=-0.25
SIM_REVERSE_TEST_OFFSET_Y=0.0
SIM_REVERSE_TEST_OFFSET_YAW_DEG=180.0
