#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname -- "${BASH_SOURCE[0]}")/.."

git pull --ff-only

if git -C src/mtt_core rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  git -C src/mtt_core pull --ff-only
fi

if ! command -v vcs >/dev/null 2>&1; then
  echo "[pull] vcs not found; skipping src/external" >&2
  exit 0
fi

if [[ ! -d src/external ]]; then
  echo "[pull] no src/external directory yet"
  exit 0
fi

if [[ -z "$(find src/external -mindepth 1 -maxdepth 1 -type d 2>/dev/null | head -n 1)" ]]; then
  echo "[pull] no external repositories checked out"
  exit 0
fi

while IFS= read -r repo_dir; do
  ! git -C "${repo_dir}" rev-parse --is-inside-work-tree >/dev/null 2>&1 && continue
  label="src/external/$(basename "${repo_dir}")"

  # Detached HEAD = tag pin; just refresh remote refs silently
  if ! git -C "${repo_dir}" symbolic-ref HEAD >/dev/null 2>&1; then
    echo "[pull] ${label}: tag pin, fetching"
    git -C "${repo_dir}" fetch --quiet
  # Branch with no upstream tracking → skip with a warning
  elif ! git -C "${repo_dir}" rev-parse '@{u}' >/dev/null 2>&1; then
    echo "[pull] ${label}: no upstream tracking branch, skipping" >&2
  else
    git -C "${repo_dir}" pull --ff-only
  fi

  # Update nested submodules (e.g. HesaiLidar_SDK_2.0)
  if [[ -f "${repo_dir}/.gitmodules" ]]; then
    echo "[pull] ${label}: updating submodules"
    git -C "${repo_dir}" submodule update --init --recursive
  fi
done < <(find src/external -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)
