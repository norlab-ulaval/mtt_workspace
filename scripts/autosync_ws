#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname -- "${BASH_SOURCE[0]}")/.."
. "$(pwd)/scripts/lib/mtt_env.sh"

print_usage() {
  cat <<'EOF'
Usage: ./scripts/autosync_ws [--watch] [--dry-run] [--no-prepare] [--eth] [--remote] [--doodle] [[user@]host] [remote_path]

Examples:
  ./scripts/autosync_ws
  ./scripts/autosync_ws --eth      # via Ethernet (192.168.3.102)
  ./scripts/autosync_ws --remote   # via Tailscale (100.77.55.41)
  ./scripts/autosync_ws --doodle   # via Doodle radio (192.168.2.2)
  ./scripts/autosync_ws <robot_user>@192.168.2.2
  ./scripts/autosync_ws --watch <robot_user>@192.168.2.2 /home/<robot_user>/Project/mtt_ws

The sync sends the workspace files that matter:
  compose.yaml  src/  docker/  scripts/  demos/  documentations/  README.md

It skips local files:
  .git  .vscode  .devcontainer  .env  build/install/log  caches  local data
EOF
}

watch_mode=false
dry_run=false
prepare_remote=true
use_eth=false
use_remote=false
use_doodle=false
positionals=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --watch)
      watch_mode=true
      shift
      ;;
    --dry-run)
      dry_run=true
      shift
      ;;
    --no-prepare)
      prepare_remote=false
      shift
      ;;
    --eth)
      use_eth=true
      shift
      ;;
    --remote)
      use_remote=true
      shift
      ;;
    --doodle)
      use_doodle=true
      shift
      ;;
    -h|--help)
      print_usage
      exit 0
      ;;
    *)
      positionals+=("$1")
      shift
      ;;
  esac
done

default_robot_user="$(mtt_env_or_file_or_default "$(pwd)" ROBOT_USER "robot")"
if [[ "${use_doodle}" == true ]]; then
  default_robot_host="$(mtt_env_or_file_or_default "$(pwd)" ROBOT_HOST_DOODLE "192.168.2.2")"
  default_robot_target="$(mtt_env_or_file_or_default "$(pwd)" ROBOT_SSH_TARGET_DOODLE "${default_robot_user}@${default_robot_host}")"
elif [[ "${use_remote}" == true ]]; then
  default_robot_host="$(mtt_env_or_file_or_default "$(pwd)" ROBOT_HOST_REMOTE "100.77.55.41")"
  default_robot_target="$(mtt_env_or_file_or_default "$(pwd)" ROBOT_SSH_TARGET_REMOTE "${default_robot_user}@${default_robot_host}")"
elif [[ "${use_eth}" == true ]]; then
  default_robot_host="$(mtt_env_or_file_or_default "$(pwd)" ROBOT_HOST_ETH "192.168.3.102")"
  default_robot_target="$(mtt_env_or_file_or_default "$(pwd)" ROBOT_SSH_TARGET_ETH "${default_robot_user}@${default_robot_host}")"
else
  default_robot_host="$(mtt_env_or_file_or_default "$(pwd)" ROBOT_HOST "192.168.2.2")"
  default_robot_target="$(mtt_env_or_file_or_default "$(pwd)" ROBOT_SSH_TARGET "${default_robot_user}@${default_robot_host}")"
fi

host="${positionals[0]:-${default_robot_target}}"
target_user="$(mtt_target_user "${host}" || true)"
target_user="${target_user:-${default_robot_user}}"

if [[ -n "${positionals[0]:-}" && -z "${positionals[1]:-}" ]]; then
  remote_path="$(mtt_default_robot_workspace "${target_user}")"
else
  remote_path="${positionals[1]:-$(mtt_env_or_file_or_default "$(pwd)" ROBOT_WORKSPACE "$(mtt_default_robot_workspace "${target_user}")")}"
fi

remote_path_quoted="$(printf '%q' "${remote_path}")"

rsync_args=(
  -az
  --delete
  --delete-excluded
  --info=NAME,STATS
)

if [[ "${dry_run}" == true ]]; then
  rsync_args+=(-n)
fi

exclude_args=(
  --exclude=.git/
  --exclude=.vscode/
  --exclude=.devcontainer/
  --exclude=.env
  --exclude=.env.*
  --exclude=build/
  --exclude=install/
  --exclude=log/
  --exclude=__pycache__/
  --exclude=.pytest_cache/
  --exclude=.mypy_cache/
  --exclude=data/live_robot/
  --exclude=data/records/
  --exclude=data/raw/
  --exclude=data/processed/
  --exclude=tmp/
  --exclude=.ccache/
  --exclude='*.pyc'
  --exclude='*.pyo'
)

# The demo compose files need demos/*/.env at parse time for variable
# interpolation. create_env generates those files as symlinks to ../../.env.
# Because we sync demos/ with --delete-excluded, plain excludes would delete
# the generated remote symlinks on every sync before the final create_env step.
# Protect them on the receiver so interrupted/manual syncs do not leave Docker
# Compose without WORKSPACE.
protect_args=(
  --filter='P .env'
  --filter='P .env.*'
)

sync_entries=(
  compose.yaml
  src
  docker
  scripts
  demos
  documentations
  README.md
)

prepare_remote_workspace() {
  if [[ "${dry_run}" == true ]]; then
    echo "[autosync] dry-run: remote prepare skipped"
    return
  fi

  ssh "${host}" "mkdir -p ${remote_path_quoted}"
}

finalize_remote_workspace() {
  if [[ "${prepare_remote}" != true || "${dry_run}" == true ]]; then
    return
  fi

  ssh "${host}" "cd ${remote_path_quoted} && bash -lc '
    set -euo pipefail
    if [[ ! -x scripts/create_env ]]; then
      echo >&2 \"[autosync] missing executable scripts/create_env on remote\"
      exit 1
    fi
    ./scripts/create_env >/dev/null
    grep -q \"^WORKSPACE=\" .env
    missing_env=false
    for compose in demos/*/compose.yaml; do
      demo_dir=\${compose%/compose.yaml}
      if [[ ! -e \"\${demo_dir}/.env\" ]]; then
        echo >&2 \"[autosync] missing \${demo_dir}/.env after create_env\"
        missing_env=true
      fi
    done
    [[ \"\${missing_env}\" == false ]]
  '"
}

sync_workspace() {
  prepare_remote_workspace
  local existing_entries=()
  local entry
  for entry in "${sync_entries[@]}"; do
    if [[ -e "${entry}" ]]; then
      existing_entries+=("${entry}")
    else
      echo "[autosync] skip missing entry: ${entry}"
    fi
  done
  rsync "${rsync_args[@]}" "${protect_args[@]}" "${exclude_args[@]}" -e ssh -- "${existing_entries[@]}" "${host}:${remote_path}"
  finalize_remote_workspace
}

echo "[autosync] target: ${host}:${remote_path}"
sync_workspace

if [[ "${watch_mode}" != true ]]; then
  exit 0
fi

if ! command -v inotifywait >/dev/null 2>&1; then
  echo >&2 "[autosync] --watch needs inotifywait (install inotify-tools)"
  exit 1
fi

echo "[autosync] watching for changes..."
while inotifywait -rqq -e modify -e create -e move -e delete \
  --exclude '(\.git|\.vscode|\.devcontainer|build|install|log|__pycache__|\.pytest_cache|\.mypy_cache|data/live_robot|data/records|data/raw|data/processed|tmp)' \
  .; do
  echo "[autosync] change detected, syncing..."
  sync_workspace
done
