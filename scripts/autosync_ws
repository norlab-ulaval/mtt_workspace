#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname -- "${BASH_SOURCE[0]}")/.."
. "$(pwd)/scripts/lib/mtt_env.sh"

print_usage() {
  cat <<'EOF'
Usage: ./scripts/autosync_ws [--watch] [--dry-run] [--no-prepare] [[user@]host] [remote_path]

Examples:
  ./scripts/autosync_ws
  ./scripts/autosync_ws <robot_user>@192.168.2.2
  ./scripts/autosync_ws --watch <robot_user>@192.168.2.2 /home/<robot_user>/Project/mtt_ws

The sync sends the workspace files that matter:
  compose.yaml  src/  docker/  scripts/  demos/  doc/  README.md

It skips local files:
  .git  .vscode  .devcontainer  .env  build/install/log  caches  local data
EOF
}

watch_mode=false
dry_run=false
prepare_remote=true
positionals=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --watch)
      watch_mode=true
      shift
      ;;
    --dry-run)
      dry_run=true
      shift
      ;;
    --no-prepare)
      prepare_remote=false
      shift
      ;;
    -h|--help)
      print_usage
      exit 0
      ;;
    *)
      positionals+=("$1")
      shift
      ;;
  esac
done

default_robot_user="$(mtt_env_or_file_or_default "$(pwd)" ROBOT_USER "robot")"
default_robot_host="$(mtt_env_or_file_or_default "$(pwd)" ROBOT_HOST "192.168.2.2")"
default_robot_target="$(mtt_env_or_file_or_default "$(pwd)" ROBOT_SSH_TARGET "${default_robot_user}@${default_robot_host}")"

host="${positionals[0]:-${default_robot_target}}"
target_user="$(mtt_target_user "${host}" || true)"
target_user="${target_user:-${default_robot_user}}"

if [[ -n "${positionals[0]:-}" && -z "${positionals[1]:-}" ]]; then
  remote_path="$(mtt_default_robot_workspace "${target_user}")"
else
  remote_path="${positionals[1]:-$(mtt_env_or_file_or_default "$(pwd)" ROBOT_WORKSPACE "$(mtt_default_robot_workspace "${target_user}")")}"
fi

remote_path_quoted="$(printf '%q' "${remote_path}")"

rsync_args=(
  -az
  --delete
  --delete-excluded
  --info=NAME,STATS
)

if [[ "${dry_run}" == true ]]; then
  rsync_args+=(-n)
fi

exclude_args=(
  --exclude=.git/
  --exclude=.vscode/
  --exclude=.devcontainer/
  --exclude=.env
  --exclude=.env.*
  --exclude=build/
  --exclude=install/
  --exclude=log/
  --exclude=__pycache__/
  --exclude=.pytest_cache/
  --exclude=.mypy_cache/
  --exclude=data/live_robot/
  --exclude=data/records/
  --exclude=data/raw/
  --exclude=data/processed/
  --exclude=tmp/
  --exclude=.ccache/
  --exclude='*.pyc'
  --exclude='*.pyo'
)

sync_entries=(
  compose.yaml
  src
  docker
  scripts
  demos
  doc
  README.md
)

prepare_remote_workspace() {
  if [[ "${dry_run}" == true ]]; then
    echo "[autosync] dry-run: remote prepare skipped"
    return
  fi

  ssh "${host}" "mkdir -p ${remote_path_quoted}"
}

finalize_remote_workspace() {
  if [[ "${prepare_remote}" != true || "${dry_run}" == true ]]; then
    return
  fi

  ssh "${host}" "cd ${remote_path_quoted} && if [[ -x scripts/create_env ]]; then ./scripts/create_env >/dev/null; fi"
}

sync_workspace() {
  prepare_remote_workspace
  rsync "${rsync_args[@]}" "${exclude_args[@]}" -e ssh -- "${sync_entries[@]}" "${host}:${remote_path}"
  finalize_remote_workspace
}

echo "[autosync] target: ${host}:${remote_path}"
sync_workspace

if [[ "${watch_mode}" != true ]]; then
  exit 0
fi

if ! command -v inotifywait >/dev/null 2>&1; then
  echo >&2 "[autosync] --watch needs inotifywait (install inotify-tools)"
  exit 1
fi

echo "[autosync] watching for changes..."
while inotifywait -rqq -e modify -e create -e move -e delete \
  --exclude '(\.git|\.vscode|\.devcontainer|build|install|log|__pycache__|\.pytest_cache|\.mypy_cache|data/live_robot|data/records|data/raw|data/processed|tmp)' \
  .; do
  echo "[autosync] change detected, syncing..."
  sync_workspace
done
