#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname -- "${BASH_SOURCE[0]}")/.."

repo_root="$(pwd)"
repos_file="${repo_root}/dependencies/robot.repos"
external_root="${repo_root}/src/external"

print_usage() {
  cat <<'EOF'
Usage: ./scripts/create_ws

Bootstrap the current `mtt_workspace` repository.

What it does:
  1. prepares the local .env via ./scripts/create_env
  2. creates the local workspace directories under src/
  3. initializes Git submodules from .gitmodules
  4. falls back to dependencies/robot.repos only if .gitmodules is absent
  5. verifies that no declared submodule remains uninitialized

Requirements:
  - git available in PATH
  - access to the private GitHub repositories referenced by .gitmodules
  - vcs only for legacy fallback import from dependencies/robot.repos
EOF
}

if [[ "${1-}" == "-h" || "${1-}" == "--help" ]]; then
  print_usage
  exit 0
fi

echo "[create_ws] preparing local environment"
./scripts/create_env

mkdir -p "${repo_root}/src" "${external_root}"

if [[ -f "${repo_root}/.gitmodules" ]]; then
  echo "[create_ws] initializing Git submodules from .gitmodules"
  git submodule sync --recursive
  git submodule update --init --recursive
else
  if ! command -v vcs >/dev/null 2>&1; then
    cat >&2 <<'EOF'
[create_ws] .gitmodules is absent and vcstool is required for fallback import, but 'vcs' was not found.

Install it first, for example:
  sudo apt install vcstool
EOF
    exit 1
  fi

  if [[ ! -f "${repos_file}" ]]; then
    echo "[create_ws] missing manifest: ${repos_file}" >&2
    exit 1
  fi

  echo "[create_ws] validating ${repos_file}"
  vcs validate < "${repos_file}"

  echo "[create_ws] importing repositories declared in ${repos_file}"
  # robot.repos paths are relative to the workspace root (for example
  # src/mtt_core or src/external/pkg), so vcs import must run from the
  # workspace root, not from an inner directory.
  vcs import --recursive --skip-existing "${repo_root}" < "${repos_file}"
fi

if [[ -f "${repo_root}/.gitmodules" ]]; then
  submodule_status="$(git submodule status --recursive)"
  if grep -qE '^[-+U]' <<<"${submodule_status}"; then
    cat >&2 <<EOF
[create_ws] submodule verification failed.

Lines starting with:
  -  mean the submodule is not initialized
  +  mean it is not at the commit pinned by its parent
  U  mean it has unresolved conflicts

${submodule_status}
EOF
    exit 1
  fi
fi

cat <<EOF
[create_ws] workspace bootstrap complete

Next steps:
  ./scripts/compile
EOF
