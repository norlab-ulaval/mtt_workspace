{
  "name": "ROS 2 Development Container",
  "privileged": true,
  "remoteUser": "mtt",
  "build": {
    "dockerfile": "Dockerfile",
    "target": "dev",
    "args": {
      "USERNAME": "mtt",
      "ROS_DISTRO": "jazzy",
      "RMW_IMPLEMENTATION": "rmw_fastrtps_cpp"
    }
  },
  "workspaceFolder": "/home/ws",
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/ws,type=bind",
  "customizations": {
    "vscode": {
      "extensions": [
        // General
        "esbenp.prettier-vscode",
        "christian-kohler.path-intellisense",

        // Python
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "ms-python.python",

        // Cpp
        "xaver.clang-format",
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-vscode.cmake-tools",

        // ROS
        "ranch-hand-robotics.rde-ros-2"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "files.exclude": {
          "**/build": true,
          "**/install": true,
          "**/log": true
        },

        // Python
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter",
          "editor.codeActionsOnSave": {
            "source.organizeImports": "always",
            "source.fixAll": "never",
            "source.unusedImports": "never"
          }
        },
        "python.analysis.importFormat": "relative",
        "python.languageServer": "Pylance",
        "python.analysis.typeCheckingMode": "basic",
        "black-formatter.args": ["--line-length=120"],
        "python.analysis.packageIndexDepths": [
          {
            "name": "rclpy",
            "depth": 5,
            "includeAllSymbols": true
          },
          {
            "name": "matplotlib",
            "depth": 5,
            "includeAllSymbols": true
          },
          {
            "name": "scipy",
            "depth": 5,
            "includeAllSymbols": true
          },
          {
            "name": "cuda",
            "depth": 5,
            "includeAllSymbols": true
          }
        ],

        // Cpp
        "[cpp]": {
          "editor.defaultFormatter": "xaver.clang-format"
        },

        // ROS
        "ros.distro": "humble",
        "python.autoComplete.extraPaths": [
          "/opt/ros/humble/lib/python3.10/site-packages",
          "/opt/ros/humble/local/lib/python3.10/dist-packages"
        ],
        "python.analysis.extraPaths": [
          "/opt/ros/humble/lib/python3.10/site-packages",
          "/opt/ros/humble/local/lib/python3.10/dist-packages"
        ]
      }
    }
  },
  "containerEnv": {
    "DISPLAY": "unix:0",
    "ROS_DOMAIN_ID": "42",
    "ROS_AUTOMATIC_DISCOVERY_RANGE": "LOCALHOST",
    "SSH_AUTH_SOCK": "${localEnv:SSH_AUTH_SOCK}"
  },
  "runArgs": [
    "--net=host",
    "--pid=host",
    "--ipc=host",
    "-e",
    "DISPLAY=${env:DISPLAY}"
  ],

  "mounts": [
    "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind,consistency=cached",
    "source=/dev/dri,target=/dev/dri,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.ssh,target=/home/mtt/.ssh,type=bind,consistency=cached", // To forward ssh agent and git properly, see https://code.visualstudio.com/remote/advancedcontainers/sharing-git-credentials
    "source=${localEnv:HOME}/.gitconfig,target=/home/mtt/.gitconfig,type=bind"
  ],
  "onCreateCommand": ".devcontainer/on_create.bash",
  "updateContentCommand": ".devcontainer/on_update.bash"
}
