  <gazebo reference="base_link">
    <material>Gazebo/Orange</material>
  </gazebo>
  <gazebo reference="Frame_fixation_articule">
    <material>Gazebo/Blue</material>
  </gazebo>
  <gazebo reference="joint_remorque_simple">
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="MTT_remorque">
    <material>Gazebo/Orange</material>
  </gazebo>
  <!-- LiDAR Link -->
  <link name="lidar_link">
    <pose>0 0 0.2 0 0 0</pose>
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.02"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <!-- Physical pencil mark reference point -->
  <link name="reference_point">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.005"/>
      </geometry>
      <material name="mark_material">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="reference_point_joint" type="fixed">
    <parent link="base_link"/>
    <child link="reference_point"/>
    <origin rpy="0 0 0" xyz="-0.7174808381178577409 0.21597831029643155 0.52330103716210749187"/>
  </joint>
  <!-- Center LiDAR -->
  <link name="center_lidar_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.05"/>
      </geometry>
      <material name="lidar_material">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="center_lidar_joint" type="fixed">
    <parent link="reference_point"/>
    <child link="center_lidar_link"/>
    <origin rpy="0 0 1.5707963267948966" xyz="0.62 -0.266 0.355"/>
  </joint>
  <!-- Front LiDAR -->
  <link name="front_lidar_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.05"/>
      </geometry>
      <material name="lidar_material">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="front_lidar_joint" type="fixed">
    <parent link="reference_point"/>
    <child link="front_lidar_link"/>
    <origin rpy="0 0 0" xyz="1.24 -0.266 0.3302"/>
  </joint>
  <!-- Rear LiDAR -->
  <link name="rear_lidar_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.05"/>
      </geometry>
      <material name="lidar_material">
