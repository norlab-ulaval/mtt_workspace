<launch>

    <let name="urdf_path" 
        value="$(find-pkg-share the_mtt_bringup)/urdf/robot.urdf.xacro"/>

    <let name="rviz_config_path"
         value="$(find-pkg-share the_mtt_bringup)/rviz/urdf_config.rviz" />

    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description"
               value="$(command 'xacro $(var urdf_path)')"/>
    </node>

    <include file="$(find-pkg-share gazebo_ros)/launch/gazebo.launch.py">
        <arg name="world" value="$(find-pkg-share the_mtt_bringup)/worlds/test.world"/>
    </include>

    <node pkg='gazebo_ros' exec="spawn_entity.py"
          args="-topic robot_description -entity my_robot"/>

    <node pkg="joint_state_publisher_gui" exec="joint_state_publisher_gui" />

    <node pkg="rviz2" exec="rviz2" output="screen"
          args="-d $(var rviz_config_path)"/>

    
    <include file="$(find-pkg-share the_mtt_bringup)/launch/controller_config.launch.py"/>

    <include file="$(find-pkg-share the_mtt_bringup)/launch/joystick.launch.py"/>

    <include file="$(find-pkg-share the_mtt_bringup)/launch/wheel_group.launch.py"/>

    <include file="$(find-pkg-share the_mtt_bringup)/launch/yaw_steering.launch.py"/>
        
</launch>

