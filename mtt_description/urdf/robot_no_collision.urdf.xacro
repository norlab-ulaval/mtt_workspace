<?xml version="1.0"?>
<robot name="onshape"  xmlns:xacro="https://www.ros.org/wiki/xacro">

    <xacro:macro name="default_transmission" params="joint_name">
        <transmission name="transmission_${joint_name}">
            <plugin>transmission_interface/SimpleTransmission</plugin>
            <actuator name="actuator_${joint_name}" role="actuator_${joint_name}"/>
            <joint name="${joint_name}" role="${joint_name}">
                <mechanical_reduction>1.0</mechanical_reduction>
            </joint>
        </transmission>
    </xacro:macro>

    <link name="base_footprint"/>

    <link name="base_link">
    <visual>
    <origin xyz="-0.0034808381178577409154 -0.051022168970358453 0.49330103716210749187" rpy="0 -0 ${pi}" />
    <geometry>
    <mesh filename="file://$(find mtt_description)/meshes/visual/m500_ra-02_r02.stl"/>
    </geometry>
    <material name="m500_ra-02_r02_material">
    <color rgba="0.98039215686274505668 0.71372549019607844922 0.0039215686274509803377 1.0"/>
    </material>
    </visual>
    <inertial>
    <origin xyz="-0.077915421490291292272 -0.045505372990426798396 0.20037964466672920638" rpy="0 0 0"/>
    <mass value="150" />
    <inertia ixx="11.048" ixy="0"  ixz="0" iyy="58.2688" iyz="0" izz="63.68" />
    </inertial>
    </link>

   <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 -0.1" rpy="0 0 0"/>
    </joint>


