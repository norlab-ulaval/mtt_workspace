    <axis xyz="0 0 1"/>
    <limit effort="-1" velocity="20" lower="-0.52359877559829881566" upper="0.52359877559829881566"/>
    <physics>
    <simbody></simbody>
    <ode>
    <implicit_string_damper>True</implicit_string_damper>
    <fudge_factor>1</fudge_factor>
    </ode>
    <suspension>
    </suspension>
    </physics>
    </joint>

    <joint name="roll" type="revolute">
    <origin xyz="0 -1.1102230246251565404e-16 -0.057149999999851597288" rpy="-1.570796326794896558 -1.8488927466117469663e-32 -1.570796326794896558" />
    <parent link="joint_remorque_simple" />
    <child link="MTT_remorque" />
    <axis xyz="0 0 1"/>
    <limit effort="-1" velocity="20" lower="-1.570796326794896558" upper="1.570796326794896558"/>
    <physics>
    <simbody></simbody>
    <ode>
    <implicit_string_damper>True</implicit_string_damper>
    <fudge_factor>1</fudge_factor>
    </ode>
    <suspension>
    </suspension>
    </physics>
    </joint>

    <joint name="yaw" type="revolute">
    <origin xyz="3.9990233346998138586e-13 0.057149999999500017411 -0.26352500000202994102" rpy="-1.570796326794896558 2.9274135154685984966e-32 0" />
    <parent link="Frame_fixation_articule" />
    <child link="joint_remorque_simple" />
    <axis xyz="0 0 1"/>
    <limit effort="1000000000.0" velocity="20" lower="-1.0471975511965976313" upper="1.0471975511965976313"/>
    <physics>
    <simbody></simbody>
    <ode>
    <implicit_string_damper>True</implicit_string_damper>
    <fudge_factor>1</fudge_factor>
    </ode>
    <suspension>
    </suspension>
    </physics>
    </joint>
   
    <joint name="pitch" type="revolute">
    <origin xyz="-1.0511878376018575221 0.21250283103064232515 0.35775105114691785335" rpy="-1.570796326794896558 -0 -7.5633943552588769595e-16" />
    <parent link="base_link" />
    <child link="Frame_fixation_articule" />
    <axis xyz="0 0 1"/>
    <limit effort="-1" velocity="20" lower="-1.570796326794896558" upper="1.570796326794896558"/>
    <physics>
    <simbody></simbody>
    <ode>
    <implicit_string_damper>True</implicit_string_damper>
    <fudge_factor>1</fudge_factor>
    </ode>
    <suspension>
    </suspension>
    </physics>
    </joint>

    <ros2_control name="RobotController" type="system">

        <hardware>
