    <gazebo reference="base_link">
        <material>Gazebo/Orange</material>
    </gazebo>

    <gazebo reference="Frame_fixation_articule">
        <material>Gazebo/Blue</material>
    </gazebo>

    <gazebo reference="joint_remorque_simple">
        <material>Gazebo/Black</material>
    </gazebo>

    <gazebo reference="MTT_remorque">
        <material>Gazebo/Orange</material>
    </gazebo>

    
<!-- LiDAR Link -->
<link name="lidar_link">
  <pose>0 0 0.2 0 0 0</pose>

  <visual>
    <geometry>
      <cylinder length="0.05" radius="0.02"/>
    </geometry>
    <material name="green">
      <color rgba="0 1 0 1"/>
    </material>
  </visual>


  <inertial>
    <mass value="0.1"/>
    <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
             iyy="0.0001" iyz="0.0"
             izz="0.0001"/>
  </inertial>
</link>

<!-- Physical pencil mark reference point -->
<link name="reference_point">
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <sphere radius="0.005"/>
    </geometry>
    <material name="mark_material">
      <color rgba="1.0 0.0 0.0 1.0"/>
    </material>
  </visual>
</link>

<joint name="reference_point_joint" type="fixed">
  <parent link="base_link"/>
  <child link="reference_point"/>
  <origin xyz="-0.7174808381178577409 0.21597831029643155 0.52330103716210749187" rpy="0 0 0"/>
</joint>

<!-- Center LiDAR -->
<link name="center_lidar_link">
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.05" length="0.1"/>
    </geometry>
    <material name="lidar_material">
      <color rgba="0.2 0.2 0.2 1.0"/>
    </material>
  </visual>
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.1"/>
    <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
             iyy="0.0001" iyz="0.0"
             izz="0.0001"/>
  </inertial>
</link>

<joint name="center_lidar_joint" type="fixed">
  <parent link="reference_point"/>
  <child link="center_lidar_link"/>
  <origin xyz="0.62 -0.266 0.355" rpy="0 0 ${pi/2}"/>
</joint>

<!-- Front LiDAR -->
<link name="front_lidar_link">
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.05" length="0.1"/>
    </geometry>
    <material name="lidar_material">
      <color rgba="0.2 0.2 0.2 1.0"/>
    </material>
  </visual>
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.1"/>
    <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
             iyy="0.0001" iyz="0.0"
             izz="0.0001"/>
  </inertial>
</link>

<joint name="front_lidar_joint" type="fixed">
  <parent link="reference_point"/>
  <child link="front_lidar_link"/>
  <origin xyz="1.24 -0.266 0.3302" rpy="0 0 0"/>
</joint>

<!-- Rear LiDAR -->
<link name="rear_lidar_link">
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.05" length="0.1"/>
    </geometry>
    <material name="lidar_material">
      <color rgba="0.2 0.2 0.2 1.0"/>
    </material>
  </visual>
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.1"/>
    <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
             iyy="0.0001" iyz="0.0"
             izz="0.0001"/>
  </inertial>
</link>

<joint name="rear_lidar_joint" type="fixed">
  <parent link="reference_point"/>
  <child link="rear_lidar_link"/>
  <origin xyz="0.01 -0.266 0.3302" rpy="0 0 0"/>
</joint>

<!-- Legacy LiDAR (kept for compatibility) -->
<joint name="lidar_joint" type="fixed">
  <parent link="base_link"/>
  <child link="lidar_link"/>
  <origin xyz="0 0 0.8" rpy="0 0 0"/>
</joint>

<gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin"> 
    <parameters> $(find mtt_bringup)/config/control_config.yaml</parameters>
</plugin>
</gazebo>

<!-- Gazebo sensor plugin for Center LiDAR -->
<gazebo reference="center_lidar_link">
  <sensor name="center_lidar" type="gpu_lidar">
    <pose>0 0 0 0 0 0</pose>
    <update_rate>10</update_rate>
    <ray>
      <scan>
        <horizontal>
          <samples>360</samples>
          <resolution>1.0</resolution>
          <min_angle>-3.14</min_angle>
          <max_angle>3.14</max_angle>
        </horizontal>
      </scan>
      <range>
        <min>0.1</min>
        <max>30.0</max>
      </range>
    </ray>
  </sensor>
</gazebo>

<!-- Gazebo sensor plugin for Front LiDAR -->
<gazebo reference="front_lidar_link">
  <sensor name="front_lidar" type="gpu_lidar">
    <pose>0 0 0 0 0 0</pose>
    <update_rate>10</update_rate>
    <ray>
      <scan>
        <horizontal>
          <samples>360</samples>
          <resolution>1.0</resolution>
          <min_angle>-3.14</min_angle>
          <max_angle>3.14</max_angle>
        </horizontal>
      </scan>
      <range>
        <min>0.1</min>
        <max>30.0</max>
      </range>
    </ray>
  </sensor>
</gazebo>

<!-- Gazebo sensor plugin for Rear LiDAR -->
<gazebo reference="rear_lidar_link">
  <sensor name="rear_lidar" type="gpu_lidar">
    <pose>0 0 0 0 0 0</pose>
    <update_rate>10</update_rate>
    <ray>
      <scan>
        <horizontal>
          <samples>360</samples>
          <resolution>1.0</resolution>
          <min_angle>-3.14</min_angle>
          <max_angle>3.14</max_angle>
        </horizontal>
      </scan>
      <range>
        <min>0.1</min>
        <max>30.0</max>
      </range>
    </ray>
  </sensor>
</gazebo>


<gazebo>
  <plugin
    filename="gz-sim-pose-publisher-system"
    name="gz::sim::systems::PosePublisher">
  <publish_model_pose>true</publish_model_pose>
</plugin>

</gazebo>

</robot>
